<?xml version="1.0" encoding="utf-8"?>
<TableLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:stretchColumns="0,1,2">

    <TableRow android:layout_marginBottom="16dp">
        <TextView android:id="@+id/btn1" style="@style/NumButton" android:text="1" />
        <TextView android:id="@+id/btn2" style="@style/NumButton" android:text="2" />
        <TextView android:id="@+id/btn3" style="@style/NumButton" android:text="3" />
    </TableRow>

    <TableRow android:layout_marginBottom="16dp">
        <TextView android:id="@+id/btn4" style="@style/NumButton" android:text="4" />
        <TextView android:id="@+id/btn5" style="@style/NumButton" android:text="5" />
        <TextView android:id="@+id/btn6" style="@style/NumButton" android:text="6" />
    </TableRow>

    <TableRow android:layout_marginBottom="16dp">
        <TextView android:id="@+id/btn7" style="@style/NumButton" android:text="7" />
        <TextView android:id="@+id/btn8" style="@style/NumButton" android:text="8" />
        <TextView android:id="@+id/btn9" style="@style/NumButton" android:text="9" />
    </TableRow>

    <TableRow>
        <View />
        <TextView android:id="@+id/btn0" style="@style/NumButton" android:text="0" />
        <ImageView
            android:id="@+id/btnDel"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:padding="24dp"
            android:src="@drawable/ic_delete"
            android:background="?attr/selectableItemBackgroundBorderless" />
    </TableRow>
</TableLayout>